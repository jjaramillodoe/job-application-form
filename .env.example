# MongoDB connection string.
# For Atlas, use a URI like:
# mongodb+srv://<username>:<password>@<cluster-url>/<database>?retryWrites=true&w=majority
MONGODB_URI=

# MongoDB database name used by the application.
MONGODB_DB=

# Secret phrase used to encrypt and decrypt sensitive fields such as SSN and DOB.
# Keep the same value once real data has been encrypted, or existing encrypted data may not decrypt.
ENCRYPTION_KEY=

# Password required to download/export application CSV data.
DOWNLOAD_PASSWORD=

# Password required to access /dashboard.
# If omitted, the app falls back to DOWNLOAD_PASSWORD.
DASHBOARD_PASSWORD=
